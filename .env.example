# App
ENV=development
HOST=http://localhost:3000
PORT=3000
FRONT_END_URL=http://localhost:5173

# Logging
SHOW_DEBUG_LOGS=true

# JWT
JWT_SECRET=your-jwt-secret
JWT_ACCESS_EXPIRATION_MINUTES=14400
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10

# Encryption
SALT_ROUNDS=12

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ose
PGUSER=user
PGHOST=localhost
PGPORT=5432
PGDATABASE=ose
PGPASSWORD=password
PGPOOL_MAX_SIZE=10
PGPOOL_MIN_SIZE=2
PGPOOL_IDLE_TIMEOUT_MILLIS=30000

# GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_PUBLIC_ACCESS_TOKEN=your-github-public-access-token
GITHUB_READ_ORG_TOKEN=your-github-read-org-token
GITHUB_SYNC_RATE_LIMIT_DELAY_MS=1000
GITHUB_SYNC_MAX_REPOS=500
GITHUB_SYNC_CHUNK_SIZE=50

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Email (Postmark)
POSTMARK_API_TOKEN=your-postmark-api-token
POSTMARK_SENDER_EMAIL=noreply@example.com
CONTACT_RECIPIENT_EMAIL=contact@example.com
